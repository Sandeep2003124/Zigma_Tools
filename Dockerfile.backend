# Stage 1: Build (minimal – we only need runtime for Express)
FROM node:20-alpine

WORKDIR /app

# Install production dependencies only
COPY package*.json ./
RUN npm ci --omit=dev --ignore-scripts

# Copy only necessary files
COPY server.js ./

# Expose port
EXPOSE 3001

# Run as non-root for security
USER node

CMD ["node", "server.js"]